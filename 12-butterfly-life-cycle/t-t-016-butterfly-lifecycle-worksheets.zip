    <script>
        if (typeof replaceFileExtension !== "function") {
            /**
             * Return the file name/file path with a new extension
             * @param {string} oldExtn the old extension to replace
             * @param {string} newExtn the new extension to replace the old one
             * @param {string} fileName the file name or path (inlc. file name)
             * @return {string}
             */
            function replaceFileExtension(oldExtn, newExtn, fileName) {
                var lastIndex = fileName.lastIndexOf("." + oldExtn);
        
                if (lastIndex === -1) {
                    return fileName;
                }
        
                return fileName.substring(0, lastIndex) + "." + newExtn;
            }
        }
        
        var imgType = (typeof dataLayer !== 'undefined' && !!dataLayer[0] && !!dataLayer[0].support && !!dataLayer[0].support.image)?dataLayer[0].support.image:'jpg',
            page = location.pathname.split('/')[1],
            srcSets = [160, 230, 270, 345, 370, 480, 550, 630],
            sizes = {};
            sizes.resource = '(max-width: 445px) 50vw,'+
                   '(max-width: 575px) 25vw,'+
                   '(max-width: 701px) 325px,'+
                   '(max-width: 872px) 270px,'+
                   '(max-width: 1199px) 345px,'+
                   '230px';            sizes.search = '(max-width: 575px) calc(100vw - 20px),'+
                   '(max-width: 990px) 345px,'+
                   '(max-width: 1200px) 270px,'+
                   '(max-width: 1430px) 345px,'+
                   '480px';            sizes.resources = '(max-width: 575px) calc(100vw - 20px),'+
