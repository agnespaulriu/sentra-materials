        if (!ignorePrevious && !!evt.data) handler(evt.data != undefined ? evt.data : {});
        var index = evt.handlers.push(handler) - 1;
        return {
            off: function () {
                delete evt.handlers[index];
            },
        };
    },
    emit: function (event, data) {
        if (!hOP.call(events, event)) { events[event] = {handlers: [], count: 1, data: data !== undefined ? data : {} };  return;}
        var evt = events[event];
        evt.data = data !== undefined ? data : {};
        evt.count += 1;
        evt.handlers.forEach(function (fn) {
            fn(evt.data);
        });
    },
    };
})();

if(!!window.XMLHttpRequest){
    (function(open) {
        window.XMLHttpRequest.prototype.open = function() {
            this.addEventListener('load', function() {
                document.fn.events.emit('ajaxComplete', this)
            });
            open.apply(this, arguments);
        };
    })(window.XMLHttpRequest.prototype.open);
}

var jsImporter = {
    url: function (url) {
        return new Promise(function (resolve, reject) {
        var script = document.createElement('script');
        script.type = 'text/javascript';
        script.addEventListener('load', function () { return resolve() }, false);
        script.addEventListener('error', function () { return reject(url) }, false);
        document.body.appendChild(script);
        script.src = url;
        });
    },
    urls: function (urls) {
        return Promise.all(urls.map(jsImporter.url));
    }
};

</script>
