var phrase = $('#phrase');
var clearButton = $('.clearButton');
var searchButton = $('#searchSubmitButton');
var val = phrase.val();
if (val) {
    clearButton.show();
    if (clearButton.css('display') !== 'none') {
        searchButton.hide();
    }
}
phrase.on('input', function () {
    if (phrase.val() !== '') {
        clearButton.show();
        if (clearButton.css('display') !== 'none') {
            searchButton.hide();
        }
    } else {
        searchButton.show();
        clearButton.hide();
    }
});
clearButton.click(function () {
    searchButton.show();
    clearButton.hide();
    phrase.val('');
    phrase.focus();
});
$('.resourceType').on('click', function(e){
   $(e.target).closest('form').find('.dropDownType').toggleClass('hidden');
});
$(document).mouseup(function (e) {
    if ($(e.target).closest('form').find(".dropDownType").length === 0) {
      $('.dropDownType').addClass('hidden');
    }
});
$("#search_form .checkButtons").change(function () {
    var selected = [];
    $("#search_form .checkButtons").each(function() {
        if($(this).is(":checked")){
        selected.push($(this).attr('data-filter-id'));
        }
    });
    var selectedStr = selected.join(".");
    var inputField = $('#search_form').find('input[name="fa"]');
    
    if (inputField.length) {
        inputField.val(selectedStr);
    } else {
       $('#search_form').append('<input type="hidden" name="fa" value="'+selectedStr+'">');
    }
});})
</script>
