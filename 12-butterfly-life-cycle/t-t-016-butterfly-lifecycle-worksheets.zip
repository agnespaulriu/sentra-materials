<script>
    var EVT_ZENDESK_WIDGET_LOADED = 'twinkl_zendesk_widget_loaded';

    var $zenDeskLoadButton;

    (function () {
        window.addEventListener(
            'DOMContentLoaded',
            function (evt) {
                $zenDeskLoadButton = document.getElementById('zenDeskLoadButton');

                if ($zenDeskLoadButton) {
                    $zenDeskLoadButton.addEventListener('click', loadZendeskScript);
                    window.addEventListener(EVT_ZENDESK_WIDGET_LOADED, onZendeskWidgetLoaded);
                }
            }
        );

        /**
         * Set a cookie so the widget will always load for the next 2 hours
         * @param {Event} evt
         */
        function onZendeskWidgetLoaded(evt)
        {
            if (typeof createCookie === 'function') {
                createCookie('zendesk_widget_loaded', 1, 0.083);
            }
        }
    }());

    function zendeskScriptLoaded() {
        /**
         * There is a not insignificant delay between the zendesk script being added to the page and something happening
         * We need to wait until that happens before we can dismiss our trigger button and open the window
         */
        var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (!mutation.addedNodes) return;

                for (var i = 0; i < mutation.addedNodes.length; i++) {
                    var node = mutation.addedNodes[i];
                    if (
                        node instanceof Element
                        && (
                            node.getAttribute('data-product') === 'web_widget'
                            || node.classList.contains('zEWidget-webWidget')
                        )
                    ) {
                        /**
                         * Input widget has loaded
                         * - Stop observing
                         * - Hide trigger button
                         * - Open window
                         */
                        observer.disconnect();

                        setTimeout(
                            function() {
                                $zenDeskLoadButton.dispatchEvent(
                                    new Event(
                                        EVT_ZENDESK_WIDGET_LOADED,
                                        {
                                            bubbles: true
                                        }
                                    )
                                );
                                $zenDeskLoadButton.remove();
                                zE('messenger', 'open');
                            },
                            6000
                        );
                                                zE("messenger", "loginUser", function (callback) {
                            callback("eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiIsImtpZCI6ImFwcF82ODhiNTVkZTMzZmE5ZjEzNWI1NTU1NWQifQ.eyJleHRlcm5hbF9pZCI6IjI4MTIyNzUwIiwiZW1haWwiOiJ0a0BlcmVub3MtdG5nLnNjaC5pZCIsImVtYWlsX3ZlcmlmaWVkIjp0cnVlLCJzY29wZSI6InVzZXIiLCJuYW1lIjoidGtAZXJlbm9zLXRuZy5zY2guaWQiLCJpYXQiOjE3ODE5MjA0ODEsImV4cCI6MTc4MTkyNzY4MX0.A3F7QvHaYngUN0CPGF9CKABc8EJROzNGKbRTbci8BPY")
                        })
                                                // zE('messenger', 'close');
                        // zE('messenger', 'open');
                    }
                }
            })
        });

        observer.observe(document.body, {
            childList: true
            , subtree: true
            , attributes: false
            , characterData: false
        })
    }

    function loadZendeskScript() {
        $zenDeskLoadButton.removeEventListener('click', loadZendeskScript);

        var $zenDeskLoadButtonIcon = document.getElementById('zenDeskLoadButtonIcon'),
            $zenDeskLoadButtonText = document.getElementById('zenDeskLoadButtonText');

        if ($zenDeskLoadButtonIcon) {
            $zenDeskLoadButtonIcon.classList.add("d-none");
            $zenDeskLoadButtonIcon.classList.remove("u-inlineBlock");
        }

        if ($zenDeskLoadButtonText) {
            $zenDeskLoadButtonText.innerHTML = 'Loading... <img alt="Loading" class="h-1-25rem w-1-25rem" src="https://images.twinkl.co.uk/tr/raw/upload/t/images/loading.gif">';
        }

        var script = document.createElement("script");
        script.type = "text/javascript";
        script.setAttribute('id','ze-snippet');

        if (script.readyState){  //IE
            script.onreadystatechange = function() {
                if (script.readyState == "loaded" ||
                    script.readyState == "complete"){
                    script.onreadystatechange = null;
                    zendeskScriptLoaded();
                }
            };
        } else {  //Others
            script.onload = function(){
                zendeskScriptLoaded();
            };
        }

        script.src = 'https://static.zdassets.com/ekr/snippet.js?key=e2780d50-5f80-4f6b-88fc-8681d693b795';
        document.getElementsByTagName("head")[0].appendChild(script);

        $zenDeskLoadButton.dispatchEvent(
            new Event(
                EVT_ZENDESK_WIDGET_LOADED,
                {
                    bubbles: true
                }
            )
        );
    }
</script>

